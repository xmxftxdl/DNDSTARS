{
  "name": "stars-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:dm": "node scripts/vite-server.mjs --host 127.0.0.1 --port 5173 --strictPort",
    "dev:player": "node scripts/vite-server.mjs --host 127.0.0.1 --port 5174 --strictPort",
    "dev:player1": "node scripts/vite-server.mjs --host 127.0.0.1 --port 5174 --strictPort",
    "dev:player2": "node scripts/vite-server.mjs --host 127.0.0.1 --port 5175 --strictPort",
    "dev:player3": "node scripts/vite-server.mjs --host 127.0.0.1 --port 5176 --strictPort",
    "dev:table": "node scripts/start-table.mjs",
    "serve:dm": "node scripts/static-server.mjs --host 127.0.0.1 --port 5173 --root dist",
    "serve:player": "node scripts/static-server.mjs --host 127.0.0.1 --port 5174 --root dist",
    "serve:player1": "node scripts/static-server.mjs --host 127.0.0.1 --port 5174 --root dist",
    "serve:player2": "node scripts/static-server.mjs --host 127.0.0.1 --port 5175 --root dist",
    "serve:player3": "node scripts/static-server.mjs --host 127.0.0.1 --port 5176 --root dist",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:ratchet": "node scripts/eslint-ratchet.mjs",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "preview": "vite preview"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@tailwindcss/vite": "^4.3.0",
    "konva": "^10.3.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-konva": "^19.2.4",
    "react-router-dom": "^7.16.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
